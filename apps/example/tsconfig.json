{
	"extends": "@rtorcato/js-tooling/typescript/base",
	"compilerOptions": {
		"ignoreDeprecations": "5.0",
		"baseUrl": ".",
		"rootDir": "src",
		"types": [
			"@cloudflare/workers-types"
		],
		"noEmit": true
	},
	"include": [
		"src/**/*",
		"wrangler.jsonc"
	],
	"exclude": [
		"node_modules"
	]
}